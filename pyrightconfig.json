{
  "include": ["src"],
  "exclude": [
    "**/__pycache__",
    "**/.pytest_cache",
    "**/node_modules"
  ],
  "ignore": [
    "src/tablespec/completeness_validator.py",
    "src/tablespec/dependency_resolver.py",
    "src/tablespec/excel_import_git.py",
    "src/tablespec/inference/domain_types.py",
