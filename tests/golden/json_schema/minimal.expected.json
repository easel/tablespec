{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "users Schema",
  "type": "object",
  "description": "User accounts table",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Primary key"
    },
    "name": {
      "type": "string",
      "description": "User name",
      "maxLength": 100
    },
    "email": {
      "type": "string",
      "description": "Email address",
      "maxLength": 255
    }
  },
  "required": [
    "id",
    "name"
  ]
}
