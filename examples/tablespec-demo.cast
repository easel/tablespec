[32.951139, "o", "--- SQL DDL ---\r\n-- DDL for Medical_Claims\r\n-- Generated from UMF specification\r\n-- Source file modified: 2026-03-16 23:01:52\r\n\r\nCREATE TABLE Medical_Claims (\r\n    claim_id STRING NOT NULL COMMENT 'Unique claim identifier',\r\n    claim_amount DECIMAL(10,2) COMMENT 'Claim amount in USD',\r\n    provider_id STRING NOT NULL COMMENT 'Provider identifier'\r\n)\r\nCOMMENT 'Healthcare claims and billing information'\r\n;\r\n--- PySpark StructType ---\r\n"]
[32.951248, "o", "# PySpark Schema for Medical_Claims\r\n# Generated from UMF specification\r\n# Source file modified: 2026-03-16 23:01:52\r\n# NOTE: Includes data + filename-sourced columns; excludes meta_* provenance columns\r\n\r\nfrom pyspark.sql.types import StructType, StructField\r\nfrom pyspark.sql.types import StringType, IntegerType, LongType, DecimalType\r\nfrom pyspark.sql.types import FloatType, DoubleType, BooleanType, DateType, TimestampType\r\n\r\nmedical_claims_schema = StructType([\r\n    StructField(\"claim_id\", StringType(), False),\r\n    StructField(\"claim_amount\", DecimalType(), True),\r\n    StructField(\"provider_id\", StringType(), False)\r\n])\r\n--- JSON Schema ---\r\n"]
[32.951319, "o", "{\r\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r\n  \"title\": \"Medical_Claims Schema\",\r\n  \"type\": \"object\",\r\n  \"description\": \"Healthcare claims and billing information\",\r\n  \"properties\": {\r\n    \"claim_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"Unique claim identifier\"\r\n    },\r\n    \"claim_amount\": {\r\n      \"type\": \"number\",\r\n      \"description\": \"Claim amount in USD\"\r\n    },\r\n    \"provider_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"Provider identifier\",\r\n      \"examples\": [\r\n        \"PRV001\",\r\n        \"PRV002\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"claim_id\",\r\n    \"provider_id\"\r\n  ]\r\n}\r\n"]
