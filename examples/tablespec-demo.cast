[13.158072, "o", "\u001b[1;32m$ cat examples/schema.yaml\u001b[0m\r\n"]
[13.164225, "o", "version: \"1.0\"\r\ntable_name: Medical_Claims\r\ndescription: Healthcare claims and billing information\r\ncolumns:\r\n  - name: claim_id\r\n    data_type: VARCHAR\r\n    length: 50\r\n    description: Unique claim identifier\r\n    nullable:\r\n      MD: false\r\n      MP: false\r\n      ME: false\r\n  - name: claim_amount\r\n    data_type: DECIMAL\r\n    precision: 10\r\n    scale: 2\r\n    description: Claim amount in USD\r\n    nullable:\r\n      MD: true\r\n      MP: true\r\n      ME: true\r\n  - name: provider_id\r\n    data_type: VARCHAR\r\n    length: 20\r\n    description: Provider identifier\r\n    nullable:\r\n      MD: false\r\n      MP: false\r\n      ME: false\r\n    sample_values:\r\n      - \"PRV001\"\r\n      - \"PRV002\"\r\n"]
